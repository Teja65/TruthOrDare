# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/Truth_or_Dare?retryWrites=true&w=majority

# Random secret for signing backend JWTs (use a long random string)
JWT_SECRET=your_jwt_secret_here

# Firebase Admin SDK (Project Settings → Service accounts → Generate new private key)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_LINES_HERE\n-----END PRIVATE KEY-----\n"

# Render sets PORT automatically; use 4000 for local development
PORT=4000
